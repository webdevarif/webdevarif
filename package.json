{
  "name": "webdevarif",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.26.0",
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@kit/database",
    "db:migrate": "turbo run db:migrate --filter=@kit/database",
    "db:push": "turbo run db:push --filter=@kit/database",
    "db:studio": "turbo run db:studio --filter=@kit/database",
    "clean": "git clean -xdf node_modules .turbo"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "postgres": "^3.4.9",
    "tsx": "^4.22.3",
    "turbo": "^2.5.6",
    "typescript": "^5.7.3"
  }
}
