# Copy to .env.local (or .env) and fill in real values. Do not commit secrets.

# Supabase Postgres connection string.
# Use the POOLER URL (port 6543, transaction mode) — required for serverless / route handlers.
# Find it: Supabase dashboard → Project Settings → Database → Connection string → "Transaction"
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres"

# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-me-with-64-bytes-of-hex"

# Session/cookie lifetime in seconds (7 days = 604800)
SESSION_MAX_AGE=604800

# Google Maps Platform key for GM Prospecting (server-side use).
# Enable: Places API (New) + Geocoding API. Restrict by HTTP referrer + API in prod.
# https://console.cloud.google.com/google/maps-apis/credentials
GOOGLE_MAPS_API_KEY=

# Same Maps key (or a separate browser-restricted one) for the map widget +
# location autocomplete. Exposed to the client bundle via NEXT_PUBLIC_ prefix.
# In production, lock this key to your origin via HTTP referrer restrictions.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# OpenRouter — required for ANY AI feature. Single LLM gateway covering
# Anthropic / OpenAI / Google / Meta / DeepSeek etc. Sign up at
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# FreeLLMAPI — optional. Self-hosted OpenAI-compatible chat-completion
# gateway. When BOTH vars are set, pure-text chat() / chatJson() calls
# default here instead of OpenRouter and use the magic "auto" model
# (FreeLLMAPI routes internally). Calls that need OpenRouter-only
# features automatically stay on OpenRouter:
#   - webSearch: true        (FreeLLMAPI has no web plugin)
#   - image_url content      (vision lives on OpenRouter)
#   - DALL-E / FLUX image gen (separate code path, never touches this)
# Leave unset to keep behaviour identical to today (OpenRouter only).
# BASE_URL should be the root that hosts /chat/completions — e.g.
#   https://your-host.com/v1   (the helper appends /chat/completions).
FREELLMAPI_BASE_URL=
FREELLMAPI_API_KEY=

# Tracker Machine — daily rollup cron secret. Required header on the
# /api/track/cron endpoint: Authorization: Bearer <CRON_SECRET>.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Agent-facing /api/track/summary auth uses DB-managed api_keys, not env.
CRON_SECRET=
